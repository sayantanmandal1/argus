<network-security-config>
    <!-- The Argus server runs over plain HTTP on a local network, so cleartext is permitted.
         Point the app at your machine's LAN IP (e.g. http://192.168.1.20:8080). -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
